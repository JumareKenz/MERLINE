# ─── Merline Frontend Environment ───
# Copy this to .env.local for local development
# Public variables are prefixed with NEXT_PUBLIC_ and bundled into the client

# ─── API Configuration ───
# Backend API URL (used by server-side requests and client-side API calls)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Application URL ───
# The public URL of the frontend application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── WebSocket ───
# WebSocket endpoint for real-time features (Reverb)
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ─── Authentication ───
# NextAuth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-change-in-production
AUTH_URL=http://localhost:3000

# ─── Feature Flags ───
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_AI_FEATURES=false
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_MAP_FEATURES=true

# ─── Analytics ───
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Sentry (Error Tracking) ───
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── i18n (Internationalization) ───
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,fr,es,sw,ar

# ─── Map Configuration ───
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Environment ───
NODE_ENV=development
